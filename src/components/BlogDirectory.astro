---
import PostList from './PostList.astro';
import type { SearchDocument } from '../utils/search';

interface Props {
  documents: SearchDocument[];
}

const { documents } = Astro.props;
const initialDocument = documents[0];
const emptyText = 'No posts yet.';
const initialStatusText = `${documents.length} posts indexed. Move through the titles to preview them.`;
const searchPayload = JSON.stringify(documents).replace(/</g, '\\u003c');
---

<section class="directory-shell" data-directory-shell>
  <div class="directory-toolbar">
    <div class="directory-toolbar-copy">
      <p class="eyebrow">Archive</p>
      <div class="directory-toolbar-meta">
        <p class="search-note" data-search-status data-default-status={initialStatusText}>
          {initialStatusText}
        </p>
      </div>
    </div>

    <div class="directory-toolbar-actions">
      <div class="directory-searchbox">
        <button
          class="icon-button search-toggle"
          type="button"
          data-search-toggle
          aria-expanded="false"
          aria-controls="blog-search-panel"
          aria-label="Open search"
        >
          <svg viewBox="0 0 24 24" aria-hidden="true">
            <path
              d="m16 16 4.2 4.2"
              fill="none"
              stroke="currentColor"
              stroke-linecap="round"
              stroke-width="1.8"
            />
            <circle cx="11" cy="11" r="6.5" fill="none" stroke="currentColor" stroke-width="1.8" />
          </svg>
          <span class="sr-only">Search posts</span>
        </button>

        <div id="blog-search-panel" class="search-panel" data-search-panel hidden>
          <label class="sr-only" for="blog-search">Search posts</label>
          <input id="blog-search" class="search-input" type="search" autocomplete="off" spellcheck="false" />
          <button
            class="icon-button search-clear"
            type="button"
            data-clear-search
            hidden
            aria-label="Clear search"
          >
            <svg viewBox="0 0 24 24" aria-hidden="true">
              <path
                d="m6.5 6.5 11 11m0-11-11 11"
                fill="none"
                stroke="currentColor"
                stroke-linecap="round"
                stroke-width="1.8"
              />
            </svg>
          </button>
        </div>
      </div>
    </div>
  </div>

  <div class="directory-layout" data-directory-root>
    <PostList documents={documents} interactive={true} showInlinePreview={true} />

    <aside
      class:list={['directory-preview', !initialDocument && 'is-empty']}
      data-directory-preview-shell
      aria-live="polite"
    >
      {documents.map((document) => (
        <section class="preview-card" data-directory-preview data-post-id={document.id}>
          <p class="eyebrow">Preview</p>
          <h3>{document.title}</h3>
          <p class="preview-description">{document.description}</p>

          <dl class="preview-metadata">
            <div>
              <dt>Date</dt>
              <dd>{document.dateLabel}</dd>
            </div>
            <div>
              <dt>Read</dt>
              <dd>{document.readingTime} min</dd>
            </div>
            <div>
              <dt>Tags</dt>
              <dd>{document.tags.join(' / ')}</dd>
            </div>
          </dl>

          <p class="preview-excerpt">{document.excerpt}</p>
        </section>
      ))}

      {!initialDocument && (
        <section class="preview-card is-active">
          <p class="preview-excerpt">{emptyText}</p>
        </section>
      )}
    </aside>
  </div>
</section>

<script is:inline type="application/json" id="blog-search-data" set:html={searchPayload}></script>

<script>
  // @ts-nocheck
  const dataElement = document.getElementById('blog-search-data');

  if (dataElement) {
    const nonWordPattern = /[^\p{L}\p{N}\s-]+/gu;
    const hanSequencePattern = /[\p{Script=Han}]+/gu;
    const normalizeSearchText = (value) =>
      value
        .normalize('NFKC')
        .toLowerCase()
        .replace(nonWordPattern, ' ')
        .replace(/[_-]+/g, ' ')
        .replace(/\s+/g, ' ')
        .trim();
    const expandSearchQuery = (query) => {
      const normalized = normalizeSearchText(query);
      const hanTerms = [];

      for (const sequence of query.match(hanSequencePattern) ?? []) {
        const chars = Array.from(sequence);

        hanTerms.push(sequence);

        for (let index = 0; index < chars.length; index += 1) {
          hanTerms.push(chars[index]);

          for (let size = 2; size <= 4 && index + size <= chars.length; size += 1) {
            hanTerms.push(chars.slice(index, index + size).join(''));
          }
        }
      }

      return [...new Set([...normalized.split(/\s+/), ...hanTerms].filter(Boolean))].join(' ');
    };
    const tokenize = (value) => normalizeSearchText(value).split(/\s+/).filter(Boolean);
    const unique = (items) => [...new Set(items.filter(Boolean))];
    const getEditDistance = (left, right) => {
      if (left === right) {
        return 0;
      }

      if (!left.length) {
        return right.length;
      }

      if (!right.length) {
        return left.length;
      }

      const matrix = Array.from({ length: left.length + 1 }, () => new Array(right.length + 1).fill(0));

      for (let index = 0; index <= left.length; index += 1) {
        matrix[index][0] = index;
      }

      for (let index = 0; index <= right.length; index += 1) {
        matrix[0][index] = index;
      }

      for (let row = 1; row <= left.length; row += 1) {
        for (let column = 1; column <= right.length; column += 1) {
          const cost = left[row - 1] === right[column - 1] ? 0 : 1;

          matrix[row][column] = Math.min(
            matrix[row - 1][column] + 1,
            matrix[row][column - 1] + 1,
            matrix[row - 1][column - 1] + cost
          );
        }
      }

      return matrix[left.length][right.length];
    };
    const matchesWholeToken = (tokens, term) => tokens.includes(term);
    const matchesTokenPrefix = (tokens, term) => tokens.some((token) => token.startsWith(term));
    const matchesNormalizedText = (text, term) => text.includes(term);
    const getFuzzyMatchScore = (term, tokens) => {
      if (term.length < 4) {
        return 0;
      }

      const threshold = term.length >= 7 ? 2 : 1;
      let bestDistance = Number.POSITIVE_INFINITY;

      for (const token of tokens) {
        if (Math.abs(token.length - term.length) > threshold) {
          continue;
        }

        const distance = getEditDistance(term, token);

        if (distance < bestDistance) {
          bestDistance = distance;
        }
      }

      if (bestDistance > threshold) {
        return 0;
      }

      return threshold === 1 ? 16 - bestDistance * 6 : 18 - bestDistance * 5;
    };

    const documents = JSON.parse(dataElement.textContent ?? '[]');
    const shell = document.querySelector('[data-directory-shell]');
    const root = shell?.querySelector('[data-directory-root]');
    const list = root?.querySelector('[data-directory-list]');
    const previewShell = shell?.querySelector('[data-directory-preview-shell]');
    const input = /** @type {HTMLInputElement | null} */ (document.getElementById('blog-search'));
    const searchToggle = shell?.querySelector('[data-search-toggle]');
    const searchPanel = shell?.querySelector('[data-search-panel]');
    const clearButton = shell?.querySelector('[data-clear-search]');
    const status = shell?.querySelector('[data-search-status]');
    const defaultStatus = status?.getAttribute('data-default-status') ?? '';
    const entries = new Map(
      [...(root?.querySelectorAll('[data-directory-entry]') ?? [])].map((element) => [
        element.getAttribute('data-post-id'),
        element
      ])
    );
    const links = new Map(
      [...(root?.querySelectorAll('[data-directory-link]') ?? [])].map((element) => [
        element.getAttribute('data-post-id'),
        element
      ])
    );
    const previews = new Map(
      [...(root?.querySelectorAll('[data-directory-preview]') ?? [])].map((element) => [
        element.getAttribute('data-post-id'),
        element
      ])
    );
    const indexedDocuments = documents.map((document) => {
      const normalizedTitle = normalizeSearchText(document.title);
      const normalizedDescription = normalizeSearchText(document.description);
      const normalizedTags = normalizeSearchText(document.tagsText);
      const normalizedSearchTerms = normalizeSearchText(document.searchTerms);

      return {
        ...document,
        normalizedTitle,
        normalizedDescription,
        normalizedTags,
        normalizedSearchTerms,
        titleTokens: unique(tokenize(document.title)),
        descriptionTokens: unique(tokenize(document.description)),
        tagTokens: unique(tokenize(document.tagsText)),
        searchTokens: unique(tokenize(document.searchTerms))
      };
    });
    const documentsById = new Map(indexedDocuments.map((document) => [document.id, document]));

    let activeId;
    let activeAnchor;

    const canUseFloatingPreview = () =>
      typeof window !== 'undefined' && window.matchMedia('(hover: hover) and (min-width: 1081px)').matches;

    const clearPreviewPosition = () => {
      if (!previewShell) {
        return;
      }

      previewShell.style.removeProperty('left');
      previewShell.style.removeProperty('top');
    };

    const positionPreview = (anchor) => {
      if (!previewShell || !anchor || !canUseFloatingPreview()) {
        clearPreviewPosition();
        return;
      }

      const anchorRect = anchor.getBoundingClientRect();
      const previewRect = previewShell.getBoundingClientRect();
      const gap = 20;
      const viewportPadding = 16;
      let left = anchorRect.right + gap;

      if (left + previewRect.width > window.innerWidth - viewportPadding) {
        left = anchorRect.left - gap - previewRect.width;
      }

      left = Math.max(
        viewportPadding,
        Math.min(left, window.innerWidth - previewRect.width - viewportPadding)
      );

      let top = anchorRect.top - 8;
      top = Math.max(
        viewportPadding,
        Math.min(top, window.innerHeight - previewRect.height - viewportPadding)
      );

      previewShell.style.left = `${Math.round(left)}px`;
      previewShell.style.top = `${Math.round(top)}px`;
    };

    const setSearchOpen = (open, options = {}) => {
      if (!shell || !searchPanel || !searchToggle) {
        return;
      }

      shell.classList.toggle('is-search-open', open);
      searchPanel.hidden = !open;
      searchToggle.setAttribute('aria-expanded', String(open));
      searchToggle.setAttribute('aria-label', open ? 'Close search' : 'Open search');

      if (open && options.focus) {
        requestAnimationFrame(() => input?.focus());
      }
    };

    const setActive = (id, anchor) => {
      const hasActivePreview = Boolean(id && entries.has(id) && previews.has(id));
      activeId = hasActivePreview ? id : undefined;
      activeAnchor = hasActivePreview ? anchor ?? links.get(id) ?? undefined : undefined;

      root?.classList.toggle('has-active-preview', hasActivePreview);

      for (const [entryId, entry] of entries) {
        entry.classList.toggle('is-active', hasActivePreview && entryId === id);
      }

      for (const [previewId, preview] of previews) {
        preview.classList.toggle('is-active', hasActivePreview && previewId === id);
      }

      if (hasActivePreview && activeAnchor) {
        requestAnimationFrame(() => positionPreview(activeAnchor));
      } else {
        clearPreviewPosition();
      }
    };

    const renderList = (orderedIds) => {
      if (!list) {
        return;
      }

      const visible = new Set(orderedIds);

      for (const [id, entry] of entries) {
        if (visible.has(id)) {
          entry.removeAttribute('hidden');
        } else {
          entry.setAttribute('hidden', '');
        }
      }

      orderedIds.forEach((id) => {
        const entry = entries.get(id);

        if (entry) {
          list.appendChild(entry);
        }
      });

      if (!visible.has(activeId)) {
        setActive(undefined);
      }
    };

    const scoreDocument = (document, query) => {
      const normalizedQuery = normalizeSearchText(query);
      const queryTokens = unique(tokenize(query));
      const expandedTokens = unique(expandSearchQuery(query).split(/\s+/));
      const auxiliaryTokens = expandedTokens.filter((token) => !queryTokens.includes(token) && token.length >= 2);
      let score = 0;
      let matchedQueryTokens = 0;

      if (document.normalizedTitle === normalizedQuery) score += 280;
      else if (document.normalizedTitle.startsWith(normalizedQuery)) score += 220;
      else if (matchesNormalizedText(document.normalizedTitle, normalizedQuery)) score += 140;

      if (document.normalizedTags === normalizedQuery) score += 180;
      else if (document.normalizedTags.startsWith(normalizedQuery)) score += 130;
      else if (matchesNormalizedText(document.normalizedTags, normalizedQuery)) score += 90;

      if (matchesNormalizedText(document.normalizedDescription, normalizedQuery)) score += 50;
      if (matchesNormalizedText(document.normalizedSearchTerms, normalizedQuery)) score += 35;

      queryTokens.forEach((token) => {
        let tokenMatched = false;

        if (matchesWholeToken(document.titleTokens, token)) {
          score += 120;
          tokenMatched = true;
        } else if (matchesTokenPrefix(document.titleTokens, token)) {
          score += 88;
          tokenMatched = true;
        } else if (matchesNormalizedText(document.normalizedTitle, token)) {
          score += 54;
          tokenMatched = true;
        }

        if (matchesWholeToken(document.tagTokens, token)) {
          score += 92;
          tokenMatched = true;
        } else if (matchesTokenPrefix(document.tagTokens, token)) {
          score += 70;
          tokenMatched = true;
        }

        if (matchesTokenPrefix(document.descriptionTokens, token)) {
          score += 26;
          tokenMatched = true;
        }

        if (matchesWholeToken(document.searchTokens, token)) {
          score += 24;
          tokenMatched = true;
        } else if (matchesTokenPrefix(document.searchTokens, token)) {
          score += 16;
          tokenMatched = true;
        }

        if (!tokenMatched) {
          const fuzzyScore = Math.max(
            getFuzzyMatchScore(token, document.titleTokens),
            getFuzzyMatchScore(token, document.tagTokens),
            getFuzzyMatchScore(token, document.searchTokens)
          );

          if (fuzzyScore > 0) {
            score += fuzzyScore;
            tokenMatched = true;
          }
        }

        if (tokenMatched) {
          matchedQueryTokens += 1;
        }
      });

      auxiliaryTokens.forEach((token) => {
        if (matchesWholeToken(document.searchTokens, token)) {
          score += 10;
        } else if (matchesTokenPrefix(document.searchTokens, token)) {
          score += 6;
        }
      });

      if (matchedQueryTokens === 0 && score < 80) {
        return null;
      }

      return {
        id: document.id,
        matchedQueryTokens,
        score
      };
    };

    const searchDocuments = (query) => {
      const ranked = indexedDocuments
        .map((document) => scoreDocument(document, query))
        .filter(Boolean)
        .sort((left, right) => {
          if (left.matchedQueryTokens !== right.matchedQueryTokens) {
            return right.matchedQueryTokens - left.matchedQueryTokens;
          }

          if (left.score !== right.score) {
            return right.score - left.score;
          }

          return (
            Date.parse(documentsById.get(right.id)?.dateISO ?? '1970-01-01T00:00:00.000Z') -
            Date.parse(documentsById.get(left.id)?.dateISO ?? '1970-01-01T00:00:00.000Z')
          );
        });

      const topScore = ranked[0]?.score ?? 0;
      const cutoff = Math.max(45, topScore * 0.28);

      return ranked.filter((item) => item.score >= cutoff);
    };

    const updateSearch = () => {
      if (!status) {
        return;
      }

      const query = input?.value.trim() ?? '';
      clearButton?.toggleAttribute('hidden', query.length === 0);

      if (!query) {
        renderList(documents.map((document) => document.id));
        setActive(undefined);
        status.textContent = defaultStatus;
        return;
      }

      const results = searchDocuments(query);
      const orderedIds = results.map((result) => result.id);
      renderList(orderedIds);
      setActive(undefined);

      status.textContent =
        orderedIds.length > 0
          ? `${orderedIds.length} results for "${query}".`
          : `No results for "${query}". Try title, tag, Chinese, pinyin, or a shorter fuzzy query.`;
    };

    for (const [id, link] of links) {
      link.addEventListener('pointerenter', () => setActive(id ?? undefined, link));
      link.addEventListener('focus', () => setActive(id ?? undefined, link));
    }

    root?.addEventListener('pointerleave', () => setActive(undefined));
    root?.addEventListener('focusout', (event) => {
      const nextTarget = event.relatedTarget;

      if (!(nextTarget instanceof Node) || !root.contains(nextTarget)) {
        setActive(undefined);
      }
    });

    window.addEventListener(
      'resize',
      () => {
        if (activeAnchor) {
          positionPreview(activeAnchor);
        } else {
          clearPreviewPosition();
        }
      },
      { passive: true }
    );

    window.addEventListener(
      'scroll',
      () => {
        if (activeAnchor) {
          positionPreview(activeAnchor);
        }
      },
      { passive: true }
    );

    searchToggle?.addEventListener('click', () => {
      const isOpen = shell?.classList.contains('is-search-open');

      if (isOpen) {
        if (input) {
          input.value = '';
        }

        updateSearch();
        setSearchOpen(false);
        searchToggle.focus();
        return;
      }

      setSearchOpen(true, { focus: true });
    });

    clearButton?.addEventListener('click', () => {
      if (!input) {
        return;
      }

      input.value = '';
      updateSearch();
      input.focus();
    });

    input?.addEventListener('input', updateSearch);

    document.addEventListener('click', (event) => {
      if (!shell?.contains(event.target) && !input?.value.trim()) {
        setSearchOpen(false);
      }
    });

    document.addEventListener('keydown', (event) => {
      if (event.key !== 'Escape' || !shell?.classList.contains('is-search-open')) {
        return;
      }

      if (input) {
        input.value = '';
      }

      updateSearch();
      setSearchOpen(false);
      searchToggle?.focus();
    });

    updateSearch();
  }
</script>
