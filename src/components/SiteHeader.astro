---
import { siteConfig } from '../site.config';

const base = import.meta.env.BASE_URL;

function withBase(path: string) {
  const relative = path === '/' ? '.' : path.replace(/^\//, '');
  return new URL(relative, `https://placeholder${base}`).pathname;
}

function normalize(path: string) {
  return path.replace(/\/$/, '') || '/';
}

const currentPath = normalize(Astro.url.pathname);
const links = [
  { label: 'Home', href: withBase('/') },
  { label: 'Blog', href: withBase('/blog/') },
  { label: 'About', href: withBase('/about/') }
];
---

<header class="site-header container reveal">
  <a class="brand" href={withBase('/')} aria-label={`${siteConfig.name} home`}>
    <span class="brand-mark">LM</span>
    <span class="brand-copy">
      <strong>{siteConfig.name}</strong>
      <small>{siteConfig.role}</small>
    </span>
  </a>

  <nav class="site-nav" aria-label="Primary">
    {links.map((link) => (
      <a
        class:list={['nav-link', normalize(link.href) === currentPath && 'is-active']}
        href={link.href}
      >
        {link.label}
      </a>
    ))}
  </nav>
</header>
