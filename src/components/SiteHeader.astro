---
import { siteConfig } from '../site.config';

const base = import.meta.env.BASE_URL;

function withBase(path: string) {
  const relative = path === '/' ? '.' : path.replace(/^\//, '');
  return new URL(relative, `https://placeholder${base}`).pathname;
}

function normalize(path: string) {
  return path.replace(/\/$/, '') || '/';
}

const currentPath = normalize(Astro.url.pathname);
const showStudioLink = import.meta.env.DEV || import.meta.env.PUBLIC_SHOW_STUDIO === 'true';
const links = [
  { label: 'Home', href: withBase('/') },
  { label: 'Blog', href: withBase('/blog/') },
  { label: 'About', href: withBase('/about/') },
  ...(showStudioLink ? [{ label: 'Studio', href: withBase('/studio/') }] : [])
];
---

<header class="site-header container">
  <div class="brand-block">
    <a class="brand" href={withBase('/')} aria-label={`${siteConfig.name} home`}>
      {siteConfig.name}
    </a>
    <p class="brand-note">{siteConfig.role}</p>
  </div>

  <div class="site-actions">
    <nav class="site-nav" aria-label="Primary">
      {links.map((link) => (
        <a
          class:list={['nav-link', normalize(link.href) === currentPath && 'is-active']}
          href={link.href}
        >
          {link.label}
        </a>
      ))}
    </nav>

    <button class="icon-button theme-toggle" type="button" data-theme-toggle data-resolved-theme="light">
      <svg class="theme-icon theme-icon-sun" viewBox="0 0 24 24" aria-hidden="true">
        <circle cx="12" cy="12" r="4.2" fill="none" stroke="currentColor" stroke-width="1.8" />
        <path
          d="M12 2.5v2.6M12 18.9v2.6M4.9 4.9l1.9 1.9M17.2 17.2l1.9 1.9M2.5 12h2.6M18.9 12h2.6M4.9 19.1l1.9-1.9M17.2 6.8l1.9-1.9"
          fill="none"
          stroke="currentColor"
          stroke-linecap="round"
          stroke-width="1.8"
        />
      </svg>
      <svg class="theme-icon theme-icon-moon" viewBox="0 0 24 24" aria-hidden="true">
        <path
          d="M19 14.5A7.5 7.5 0 1 1 9.5 5a6.2 6.2 0 0 0 9.5 9.5Z"
          fill="none"
          stroke="currentColor"
          stroke-linejoin="round"
          stroke-width="1.8"
        />
      </svg>
      <span class="sr-only">Toggle theme</span>
    </button>
  </div>
</header>
