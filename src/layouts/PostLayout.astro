---
import BaseLayout from './BaseLayout.astro';
import { formatDate, getPostPath, getReadingTime } from '../utils/content';
import type { Post } from '../utils/content';

interface Props {
  post: Post;
  previous?: Post;
  next?: Post;
}

const { post, previous, next } = Astro.props;
---

<BaseLayout title={post.data.title} description={post.data.description} pageClass="page-article">
  <article class="article-shell">
    <header class="article-intro reveal">
      <p class="eyebrow">Essay</p>
      <h1>{post.data.title}</h1>
      <p class="article-lead">{post.data.description}</p>
      <div class="meta-row">
        <span>{formatDate(post.data.date)}</span>
        <span>{getReadingTime(post.body)} min read</span>
        <span>{post.data.tags.join(' / ')}</span>
      </div>
    </header>

    <div class="prose reveal-delay">
      <slot />
    </div>

    <nav class="glass-card article-navigation reveal-slower" aria-label="Post navigation">
      <div class="nav-stack">
        <p class="label">Previous</p>
        {
          previous ? (
            <a class="text-link" href={getPostPath(previous)}>
              {previous.data.title}
            </a>
          ) : (
            <span class="caption">No earlier essay yet.</span>
          )
        }
      </div>

      <div class="nav-stack">
        <p class="label">Next</p>
        {
          next ? (
            <a class="text-link" href={getPostPath(next)}>
              {next.data.title}
            </a>
          ) : (
            <span class="caption">You are at the latest note.</span>
          )
        }
      </div>
    </nav>
  </article>
</BaseLayout>
