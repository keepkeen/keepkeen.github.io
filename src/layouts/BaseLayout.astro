---
import '@fontsource-variable/manrope';
import '@fontsource/jetbrains-mono';
import 'katex/dist/katex.min.css';
import '../styles/global.css';

import SiteFooter from '../components/SiteFooter.astro';
import SiteHeader from '../components/SiteHeader.astro';
import { siteConfig } from '../site.config';
import { withBasePath } from '../utils/content';
import { getDefaultSocialImage, getSiteJsonLd, type JsonLd } from '../utils/structured-data';

interface Props {
  title?: string;
  description?: string;
  pageClass?: string;
  image?: string;
  keywords?: string[];
  ogType?: 'website' | 'article';
  publishedTime?: Date | string;
  modifiedTime?: Date | string;
  articleTags?: string[];
  jsonLd?: JsonLd | JsonLd[];
  includeSiteJsonLd?: boolean;
  noindex?: boolean;
}

const {
  title,
  description = siteConfig.description,
  pageClass = '',
  image,
  keywords = [],
  ogType = 'website',
  publishedTime,
  modifiedTime,
  articleTags = [],
  jsonLd,
  includeSiteJsonLd = true,
  noindex = false
} = Astro.props;
const metaTitle = title ? `${title} | ${siteConfig.name}` : siteConfig.defaultTitle;
const siteOrigin = Astro.site ?? new URL(siteConfig.siteUrl);
const canonical = new URL(Astro.url.pathname, siteOrigin);
const iconHref = `${import.meta.env.BASE_URL}favicon.svg`;
const rssHref = withBasePath('/rss.xml');
const socialImage = new URL(image ?? getDefaultSocialImage(siteOrigin), siteOrigin).toString();
const normalizedPublishedTime =
  publishedTime instanceof Date ? publishedTime.toISOString() : publishedTime;
const normalizedModifiedTime =
  modifiedTime instanceof Date ? modifiedTime.toISOString() : modifiedTime;
const jsonLdItems = [
  ...(includeSiteJsonLd ? getSiteJsonLd(siteOrigin) : []),
  ...(Array.isArray(jsonLd) ? jsonLd : jsonLd ? [jsonLd] : [])
];
const robotsContent = noindex ? 'noindex, nofollow' : 'index, follow, max-image-preview:large';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{metaTitle}</title>
    <meta name="description" content={description} />
    <meta name="author" content={siteConfig.name} />
    <meta name="robots" content={robotsContent} />
    <meta name="color-scheme" content="light dark" />
    <link rel="canonical" href={canonical.toString()} />
    <link rel="icon" type="image/svg+xml" href={iconHref} />
    <link rel="alternate" type="application/rss+xml" title={`${siteConfig.name} RSS`} href={rssHref} />
    <meta id="theme-color-meta" name="theme-color" content="#ffffff" />
    {keywords.length > 0 && <meta name="keywords" content={keywords.join(', ')} />}
    <meta property="og:type" content={ogType} />
    <meta property="og:site_name" content={siteConfig.name} />
    <meta property="og:title" content={metaTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical.toString()} />
    <meta property="og:image" content={socialImage} />
    <meta property="og:image:type" content="image/svg+xml" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={metaTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={socialImage} />
    {normalizedPublishedTime && <meta property="article:published_time" content={normalizedPublishedTime} />}
    {normalizedModifiedTime && <meta property="article:modified_time" content={normalizedModifiedTime} />}
    {articleTags.map((tag) => (
      <meta property="article:tag" content={tag} />
    ))}
    {jsonLdItems.map((entry) => (
      <script is:inline type="application/ld+json" set:html={JSON.stringify(entry)} />
    ))}
    <script is:inline>
      (() => {
        const STORAGE_KEY = 'blog-theme-preference';
        const LIGHT = 'light';
        const DARK = 'dark';
        const media = window.matchMedia('(prefers-color-scheme: dark)');
        const root = document.documentElement;
        const themeMeta = document.getElementById('theme-color-meta');
        const readPreference = () => {
          try {
            const value = window.localStorage.getItem(STORAGE_KEY);
            return value === LIGHT || value === DARK ? value : null;
          } catch {
            return null;
          }
        };
        const writePreference = (value) => {
          try {
            if (value) {
              window.localStorage.setItem(STORAGE_KEY, value);
            } else {
              window.localStorage.removeItem(STORAGE_KEY);
            }
          } catch {
            return;
          }
        };
        const resolveTheme = (preference) => preference ?? (media.matches ? DARK : LIGHT);
        const apply = (preference, persist = true) => {
          const resolved = resolveTheme(preference);

          if (preference) {
            root.dataset.themePreference = preference;
          } else {
            delete root.dataset.themePreference;
          }

          root.dataset.theme = resolved;
          root.style.colorScheme = resolved;
          themeMeta?.setAttribute('content', resolved === DARK ? '#0d1015' : '#ffffff');

          if (persist) {
            writePreference(preference);
          }

          window.__blogTheme?.syncButtons?.();
        };

        const toggle = () => {
          const currentResolved = root.dataset.theme || resolveTheme(readPreference());
          apply(currentResolved === DARK ? LIGHT : DARK);
        };

        window.__blogTheme = {
          media,
          apply,
          toggle,
          getStoredPreference: readPreference,
          getResolvedTheme: () => root.dataset.theme || resolveTheme(readPreference()),
          syncButtons: () => {}
        };

        apply(readPreference(), false);

        const handleMediaChange = () => {
          if (!readPreference()) {
            apply(null, false);
          } else {
            window.__blogTheme?.syncButtons?.();
          }
        };

        media.addEventListener('change', handleMediaChange);
      })();
    </script>
  </head>

  <body class={pageClass}>
    <div class="page-shell">
      <SiteHeader />
      <main class="main-content">
        <slot />
      </main>
      <SiteFooter />
    </div>

    <script is:inline>
      const COPY_LABEL = 'Copy';
      const COPIED_LABEL = 'Copied';
      const syncThemeButtons = () => {
        const resolved = document.documentElement.dataset.theme || window.__blogTheme?.getResolvedTheme?.() || 'light';
        const next = resolved === 'dark' ? 'light' : 'dark';

        document.querySelectorAll('[data-theme-toggle]').forEach((button) => {
          button.dataset.resolvedTheme = resolved;
          button.setAttribute('aria-label', `Current ${resolved} theme. Activate to switch to ${next}.`);
          button.setAttribute('title', `Switch to ${next} theme`);
        });
      };
      const bindThemeButtons = () => {
        document.querySelectorAll('[data-theme-toggle]').forEach((button) => {
          if (button.dataset.themeBound === 'true') {
            return;
          }

          button.dataset.themeBound = 'true';
          button.addEventListener('click', () => {
            window.__blogTheme?.toggle?.();
            syncThemeButtons();
          });
        });
      };

      const attachCopyButton = (container, getText) => {
        if (container.dataset.copyReady === 'true') {
          return;
        }

        const button = document.createElement('button');
        button.type = 'button';
        button.className = 'copy-button';
        button.textContent = COPY_LABEL;

        button.addEventListener('click', async () => {
          const text = getText().trim();

          if (!text) {
            return;
          }

          try {
            await navigator.clipboard.writeText(text);
            button.textContent = COPIED_LABEL;
            window.setTimeout(() => {
              button.textContent = COPY_LABEL;
            }, 1600);
          } catch (error) {
            button.textContent = 'Failed';
            window.setTimeout(() => {
              button.textContent = COPY_LABEL;
            }, 1600);
            console.error(error);
          }
        });

        container.dataset.copyReady = 'true';
        container.appendChild(button);
      };

      const enhanceArticleUtilities = () => {
        document.querySelectorAll('.prose pre').forEach((block) => {
          attachCopyButton(block, () => block.querySelector('code')?.textContent ?? block.textContent ?? '');
        });

        document.querySelectorAll('.prose .katex-display').forEach((block) => {
          block.classList.add('math-block');
          attachCopyButton(
            block,
            () =>
              block.querySelector('annotation[encoding="application/x-tex"]')?.textContent ??
              block.textContent ??
              ''
          );
        });

        bindThemeButtons();
        window.__blogTheme.syncButtons = syncThemeButtons;
        syncThemeButtons();
      };

      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', enhanceArticleUtilities, { once: true });
      } else {
        enhanceArticleUtilities();
      }

      window.__blogTheme?.media?.addEventListener?.('change', () => {
        if ((document.documentElement.dataset.themeMode || window.__blogTheme?.getStoredMode?.()) === 'system') {
          window.__blogTheme?.apply?.('system', false);
          syncThemeButtons();
        }
      });

      document.addEventListener('astro:page-load', enhanceArticleUtilities);
    </script>
  </body>
</html>
