---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { formatDate, getPostPath, getReadingTime, sortPosts } from '../../utils/content';

const posts = sortPosts(await getCollection('posts', ({ data }) => !data.draft));
const tags = [...new Set(posts.flatMap((post) => post.data.tags))];
const latestDate = posts.at(0)?.data.date;
---

<BaseLayout title="Blog" description="Essays, field notes, and technical reflections.">
  <section class="page-intro reveal">
    <p class="eyebrow">Archive</p>
    <h1>Essays, notebooks, and field notes.</h1>
    <p class="section-copy">
      This archive is meant to be scanned like an index rather than consumed like a feed. Technical
      notes, longer essays, and slower reflections live in the same catalog.
    </p>
  </section>

  <section class="archive-layout reveal-delay">
    <aside class="glass-card archive-aside">
      <p class="label">Archive Signals</p>
      <div class="fact-grid">
        <div class="fact-item">
          <span>Entries</span>
          <strong>{posts.length}</strong>
        </div>
        <div class="fact-item">
          <span>Themes</span>
          <strong>{tags.length}</strong>
        </div>
        <div class="fact-item">
          <span>Latest</span>
          <strong>{latestDate ? formatDate(latestDate) : 'Soon'}</strong>
        </div>
        <div class="fact-item">
          <span>Format</span>
          <strong>Essay / note / reflection</strong>
        </div>
      </div>

      <div class="divider"></div>

      <p class="label">Tags</p>
      <div class="pill-list">
        {tags.map((tag) => (
          <span class="pill">{tag}</span>
        ))}
      </div>
    </aside>

    <div class="archive-list">
      {posts.map((post) => (
        <article class="archive-entry">
          <div class="archive-meta">
            <span>{formatDate(post.data.date)}</span>
            <span>{getReadingTime(post.body)} min read</span>
          </div>

          <div class="archive-main">
            <h2>
              <a class="feature-link" href={getPostPath(post)}>
                {post.data.title}
              </a>
            </h2>
            <p>{post.data.description}</p>
            <div class="pill-list">
              {post.data.tags.map((tag) => (
                <span class="pill">{tag}</span>
              ))}
            </div>
          </div>
        </article>
      ))}
    </div>
  </section>
</BaseLayout>
