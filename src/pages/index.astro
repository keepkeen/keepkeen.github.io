---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import { siteConfig } from '../site.config';
import { formatDate, getPostPath, getReadingTime, sortPosts, withBasePath } from '../utils/content';

const posts = sortPosts(await getCollection('posts', ({ data }) => !data.draft));
const latestPosts = posts.slice(0, 4);
---

<BaseLayout>
  <section class="editorial-hero home-hero">
    <div class="editorial-hero-main">
      <p class="eyebrow">{siteConfig.hero.eyebrow}</p>
      <h1>{siteConfig.hero.headline}</h1>
      <p class="section-copy">{siteConfig.hero.lead}</p>
    </div>

    <div class="editorial-hero-side">
      <p class="hero-note">{siteConfig.hero.deck}</p>
      <p class="hero-signature">{siteConfig.hero.signature}</p>

      <div class="hero-links">
        <a class="text-link" href={withBasePath('/blog/')}>Browse the archive</a>
        <a class="text-link" href={withBasePath('/about/')}>About the author</a>
      </div>
    </div>
  </section>

  <section class="section editorial-section">
    <div class="section-rail">
      <div class="section-rail-head">
        <p class="eyebrow">Recent posts</p>
        <h2 class="section-title">Start from the latest writing.</h2>
      </div>
      <div class="section-rail-body">
        <div class="section-rail-intro">
          <p class="section-copy">
            The home page and the archive now share the same grammar: short lead-in, ruled lists,
            and quiet metadata instead of decorative blocks.
          </p>
          <a class="text-link" href={withBasePath('/blog/')}>Open the full directory</a>
        </div>

        <div class="stack-list">
          {latestPosts.map((post) => (
            <article class="list-entry">
              <div class="entry-topline">
                <span>{formatDate(post.data.date)}</span>
                <span>{getReadingTime(post.body)} min read</span>
              </div>

              <div class="list-entry-main">
                <div>
                  <h3>
                    <a href={getPostPath(post)}>{post.data.title}</a>
                  </h3>
                  <p>{post.data.description}</p>
                </div>

                <div class="entry-tags" aria-label="Tags">
                  {post.data.tags.map((tag) => (
                    <span>{tag}</span>
                  ))}
                </div>
              </div>
            </article>
          ))}
        </div>
      </div>
    </div>
  </section>

  <section class="section editorial-section">
    <div class="section-rail">
      <div class="section-rail-head">
        <p class="eyebrow">Current focus</p>
        <h2 class="section-title">What the writing keeps returning to.</h2>
      </div>
      <div class="section-rail-body">
        <div class="stack-list">
          {siteConfig.currentFocus.map((item, index) => (
            <article class="note-row">
              <p class="note-index">{String(index + 1).padStart(2, '0')}</p>
              <p>{item}</p>
            </article>
          ))}
        </div>
      </div>
    </div>
  </section>

  <section class="section editorial-section">
    <div class="section-rail">
      <div class="section-rail-head">
        <p class="eyebrow">Writing map</p>
        <h2 class="section-title">Four recurring threads.</h2>
      </div>
      <div class="section-rail-body">
        <div class="topic-list">
          {siteConfig.topicCards.map((card) => (
            <article class="topic-item">
              <div class="topic-lead">
                <p class="topic-index">{card.index}</p>
                <div>
                  <p class="topic-kicker">{card.kicker}</p>
                  <h3>{card.title}</h3>
                </div>
              </div>
              <p>{card.description}</p>
            </article>
          ))}
        </div>
      </div>
    </div>
  </section>

  <section class="section editorial-section">
    <div class="section-rail">
      <div class="section-rail-head">
        <p class="eyebrow">Principles</p>
        <h2 class="section-title">The constraints behind the publication.</h2>
      </div>
      <div class="section-rail-body section-rail-body-columns">
        <article>
          <p class="panel-label">Editorial rules</p>
          <ul class="plain-list">
            {siteConfig.principles.map((principle) => (
              <li>{principle}</li>
            ))}
          </ul>
        </article>

        <article>
          <p class="panel-label">Working notes</p>
          <ul class="plain-list">
            {siteConfig.studioNotes.map((note) => (
              <li>{note}</li>
            ))}
          </ul>
        </article>
      </div>
    </div>
  </section>
</BaseLayout>
