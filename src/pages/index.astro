---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import { siteConfig } from '../site.config';
import { formatDate, getPostPath, getReadingTime, sortPosts, withBasePath } from '../utils/content';

const posts = sortPosts(await getCollection('posts', ({ data }) => !data.draft));
const latestPosts = posts.slice(0, 3);
const [featuredPost, ...secondaryPosts] = latestPosts;
---

<BaseLayout>
  <section class="hero home-hero reveal">
    <div class="hero-copy">
      <p class="eyebrow">{siteConfig.hero.eyebrow}</p>
      <h1>{siteConfig.hero.headline}</h1>
      <p class="hero-deck">{siteConfig.hero.lead}</p>
      <p class="hero-signature">{siteConfig.hero.signature}</p>

      <div class="hero-actions">
        <a class="button button-primary" href={withBasePath('/blog/')}>Read the essays</a>
        <a class="button" href={withBasePath('/about/')}>About me</a>
      </div>
    </div>

    <aside class="glass-card desk-panel reveal-delay">
      <p class="label">From the Desk</p>
      <p class="desk-intro">{siteConfig.hero.deck}</p>

      <div class="fact-grid">
        {siteConfig.deskFacts.map((fact) => (
          <div class="fact-item">
            <span>{fact.label}</span>
            <strong>{fact.value}</strong>
          </div>
        ))}
      </div>

      <div class="divider"></div>

      <p class="label">Current Focus</p>
      <ul class="note-list">
        {siteConfig.currentFocus.map((item) => (
          <li>{item}</li>
        ))}
      </ul>
    </aside>
  </section>

  <section class="section reveal-delay">
    <div class="section-header editorial-header">
      <div>
        <p class="eyebrow">Writing Map</p>
        <h2 class="section-title">Four directions, one underlying taste.</h2>
      </div>
      <p class="section-copy">
        The common thread is not topic, but method: reduce noise, increase signal, and keep the
        thinking calm enough to hold up over time.
      </p>
    </div>

    <div class="map-grid">
      {siteConfig.topicCards.map((card) => (
        <article class="glass-card map-card">
          <span class="topic-index">{card.index}</span>
          <p class="map-kicker">{card.kicker}</p>
          <h3>{card.title}</h3>
          <p>{card.description}</p>
        </article>
      ))}
    </div>
  </section>

  {featuredPost && (
    <section class="section reveal-slower">
      <div class="section-header editorial-header">
        <div>
          <p class="eyebrow">Selected Writing</p>
          <h2 class="section-title">Recent essays from the notebook.</h2>
        </div>
        <p class="section-copy">
          Some pieces are technical, some reflective, but all are meant to read with the same
          editorial rhythm.
        </p>
      </div>

      <div class="featured-grid">
        <article class="glass-card featured-primary">
          <p class="label">Featured Essay</p>
          <div class="meta-row">
            <span>{formatDate(featuredPost.data.date)}</span>
            <span>{getReadingTime(featuredPost.body)} min read</span>
          </div>
          <h2>
            <a class="feature-link" href={getPostPath(featuredPost)}>
              {featuredPost.data.title}
            </a>
          </h2>
          <p class="featured-excerpt">{featuredPost.data.description}</p>
          <div class="pill-list">
            {featuredPost.data.tags.map((tag) => (
              <span class="pill">{tag}</span>
            ))}
          </div>
        </article>

        <div class="featured-secondary">
          {secondaryPosts.map((post) => (
            <article class="glass-card mini-post">
              <div class="meta-row">
                <span>{formatDate(post.data.date)}</span>
                <span>{getReadingTime(post.body)} min read</span>
              </div>
              <h3>
                <a class="feature-link" href={getPostPath(post)}>
                  {post.data.title}
                </a>
              </h3>
              <p>{post.data.description}</p>
            </article>
          ))}
        </div>
      </div>
    </section>
  )}

  <section class="section reveal-slower">
    <div class="section-header editorial-header">
      <div>
        <p class="eyebrow">Field Notes</p>
        <h2 class="section-title">What this publication is trying to learn.</h2>
      </div>
      <a class="text-link" href={withBasePath('/blog/')}>Browse the full archive</a>
    </div>

    <div class="tri-panel">
      <article class="glass-card note-panel">
        <p class="label">Current Questions</p>
        <ol class="question-list">
          {siteConfig.currentQuestions.map((item) => (
            <li>{item}</li>
          ))}
        </ol>
      </article>

      <article class="glass-card note-panel">
        <p class="label">Operating Principles</p>
        <ul class="principle-list">
          {siteConfig.principles.map((principle) => (
            <li>{principle}</li>
          ))}
        </ul>
      </article>

      <article class="glass-card note-panel">
        <p class="label">Studio Notes</p>
        <ul class="note-list">
          {siteConfig.studioNotes.map((note) => (
            <li>{note}</li>
          ))}
        </ul>
      </article>
    </div>
  </section>
</BaseLayout>
