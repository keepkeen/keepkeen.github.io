---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import { siteConfig } from '../site.config';
import { formatDate, getPostPath, getReadingTime, sortPosts, withBasePath } from '../utils/content';

const posts = sortPosts(await getCollection('posts', ({ data }) => !data.draft));
const latestPosts = posts.slice(0, 3);
---

<BaseLayout>
  <section class="home-intro">
    <div class="page-intro page-intro-home">
      <div>
        <p class="eyebrow">{siteConfig.hero.eyebrow}</p>
        <h1>{siteConfig.name}</h1>
      </div>
      <p class="section-copy">
        {siteConfig.hero.lead}
      </p>
    </div>

    <div class="home-summary-grid">
      <div class="plain-panel">
        <p class="panel-label">What this site is</p>
        <p class="panel-copy">{siteConfig.hero.deck}</p>

        <div class="button-row">
          <a class="button button-primary" href={withBasePath('/blog/')}>Browse posts</a>
          <a class="button" href={withBasePath('/about/')}>About</a>
        </div>
      </div>

      <div class="plain-panel">
        <p class="panel-label">Current focus</p>
        <ul class="plain-list">
          {siteConfig.currentFocus.map((item) => (
            <li>{item}</li>
          ))}
        </ul>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="section-header">
      <div>
        <p class="eyebrow">Recent posts</p>
        <h2 class="section-title">Start from the latest writing.</h2>
      </div>
      <a class="text-link" href={withBasePath('/blog/')}>Open the full directory</a>
    </div>

    <div class="stack-list">
      {latestPosts.map((post) => (
        <article class="list-entry">
          <div class="entry-topline">
            <span>{formatDate(post.data.date)}</span>
            <span>{getReadingTime(post.body)} min read</span>
          </div>

          <div class="list-entry-main">
            <div>
              <h3>
                <a href={getPostPath(post)}>{post.data.title}</a>
              </h3>
              <p>{post.data.description}</p>
            </div>

            <div class="entry-tags" aria-label="Tags">
              {post.data.tags.map((tag) => (
                <span>{tag}</span>
              ))}
            </div>
          </div>
        </article>
      ))}
    </div>
  </section>

  <section class="section section-grid">
    <div class="plain-panel">
      <p class="panel-label">Writing map</p>
      <div class="topic-list">
        {siteConfig.topicCards.map((card) => (
          <article class="topic-item">
            <div>
              <p class="topic-kicker">{card.kicker}</p>
              <h3>{card.title}</h3>
            </div>
            <p>{card.description}</p>
          </article>
        ))}
      </div>
    </div>

    <div class="plain-panel">
      <div class="section-header section-header-compact">
        <div>
          <p class="eyebrow">Working notes</p>
          <h2 class="section-title section-title-compact">A few recurring questions.</h2>
        </div>
      </div>

      <ol class="number-list">
        {siteConfig.currentQuestions.map((item) => (
          <li>{item}</li>
        ))}
      </ol>
    </div>
  </section>

  <section class="section">
    <div class="section-header">
      <div>
        <p class="eyebrow">Principles</p>
        <h2 class="section-title">The constraints behind the writing.</h2>
      </div>
      <a class="text-link" href={withBasePath('/blog/')}>Browse the full archive</a>
    </div>

    <div class="simple-grid">
      <div class="plain-panel">
        <ul class="plain-list">
          {siteConfig.principles.map((principle) => (
            <li>{principle}</li>
          ))}
        </ul>
      </div>

      <div class="plain-panel">
        <ul class="plain-list">
          {siteConfig.studioNotes.map((note) => (
            <li>{note}</li>
          ))}
        </ul>
      </div>
    </div>
  </section>
</BaseLayout>
