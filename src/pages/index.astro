---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import PostList from '../components/PostList.astro';
import { siteConfig } from '../site.config';
import { buildSearchDocument } from '../utils/search';
import { sortPosts, withBasePath } from '../utils/content';

const posts = sortPosts(await getCollection('posts', ({ data }) => !data.draft));
const latestPosts = posts.slice(0, 4);
const latestDocuments = latestPosts.map((post) => buildSearchDocument(post));
---

<BaseLayout>
  <section class="editorial-hero home-hero">
    <div class="editorial-hero-main">
      <p class="eyebrow">{siteConfig.hero.eyebrow}</p>
      <h1>{siteConfig.hero.headline}</h1>
      <p class="section-copy">{siteConfig.hero.lead}</p>
    </div>

    <div class="editorial-hero-side">
      <p class="hero-note">{siteConfig.hero.deck}</p>
      <p class="hero-signature">{siteConfig.hero.signature}</p>

      <div class="hero-links">
        <a class="text-link" href={withBasePath('/blog/')}>Browse the archive</a>
        <a class="text-link" href={withBasePath('/about/')}>About the author</a>
      </div>
    </div>
  </section>

  <section class="directory-shell home-directory-shell">
    <div class="directory-toolbar">
      <div class="directory-toolbar-copy">
        <p class="eyebrow">Recent writing</p>
        <div class="directory-toolbar-meta">
          <p class="search-note">
            {latestPosts.length} latest posts from the publication.
          </p>
          <a class="text-link directory-toolbar-link" href={withBasePath('/blog/')}>Open the full archive</a>
        </div>
      </div>
    </div>

    <PostList documents={latestDocuments} />
  </section>

  <section class="section editorial-section">
    <div class="section-rail">
      <div class="section-rail-head">
        <p class="eyebrow">Writing map</p>
        <h2 class="section-title">What this publication keeps returning to.</h2>
      </div>
      <div class="section-rail-body section-rail-body-columns">
        <article>
          <div class="topic-list">
            {siteConfig.topicCards.map((card) => (
              <article class="topic-item">
                <div class="topic-lead">
                  <p class="topic-index">{card.index}</p>
                  <div>
                    <p class="topic-kicker">{card.kicker}</p>
                    <h3>{card.title}</h3>
                  </div>
                </div>
                <p>{card.description}</p>
              </article>
            ))}
          </div>
        </article>

        <article>
          <p class="panel-label">Current focus</p>
          <div class="stack-list">
            {siteConfig.currentFocus.map((item, index) => (
              <article class="note-row">
                <p class="note-index">{String(index + 1).padStart(2, '0')}</p>
                <p>{item}</p>
              </article>
            ))}
          </div>

          <div class="divider"></div>

          <p class="panel-label">Editorial rules</p>
          <ul class="plain-list">
            {siteConfig.principles.map((principle) => (
              <li>{principle}</li>
            ))}
          </ul>
        </article>
      </div>
    </div>
  </section>
</BaseLayout>
