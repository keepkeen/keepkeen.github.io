---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import PostCard from '../components/PostCard.astro';
import { siteConfig } from '../site.config';
import { sortPosts, withBasePath } from '../utils/content';

const posts = sortPosts(await getCollection('posts', ({ data }) => !data.draft));
const latestPosts = posts.slice(0, 3);
const distinctTags = [...new Set(posts.flatMap((post) => post.data.tags))].slice(0, 8);
---

<BaseLayout>
  <section class="hero reveal">
    <div class="hero-copy">
      <p class="eyebrow">{siteConfig.hero.eyebrow}</p>
      <h1>{siteConfig.hero.headline}</h1>
      <p class="hero-lead">{siteConfig.hero.lead}</p>

      <div class="hero-actions">
        <a class="button button-primary" href={withBasePath('/blog/')}>Read the essays</a>
        <a class="button" href={withBasePath('/about/')}>About me</a>
      </div>
    </div>

    <aside class="glass-card hero-panel reveal-delay">
      <p class="label">Current Compass</p>
      <ul class="bullet-list">
        {siteConfig.currentFocus.map((item) => (
          <li>{item}</li>
        ))}
      </ul>

      <div class="divider"></div>

      <div class="stat-grid">
        <div>
          <span class="stat-value">{posts.length}</span>
          <span class="stat-label">Published essays</span>
        </div>
        <div>
          <span class="stat-value">{distinctTags.length}</span>
          <span class="stat-label">Recurring themes</span>
        </div>
      </div>
    </aside>
  </section>

  <section class="section reveal-delay">
    <div class="section-header">
      <div>
        <p class="eyebrow">What Lives Here</p>
        <h2 class="section-title">A portfolio of ideas, not noise.</h2>
      </div>
      <p class="section-copy">
        The site is built as a polished writing surface: technical enough for equations and code,
        restrained enough to let taste and thought carry the experience.
      </p>
    </div>

    <div class="topic-grid">
      {siteConfig.topicCards.map((card) => (
        <article class="glass-card topic-card">
          <span class="topic-index">{card.index}</span>
          <h3>{card.title}</h3>
          <p>{card.description}</p>
        </article>
      ))}
    </div>
  </section>

  <section class="section reveal-slower">
    <div class="section-header">
      <div>
        <p class="eyebrow">Latest Essays</p>
        <h2 class="section-title">Recent notes and long-form pieces.</h2>
      </div>
      <a class="text-link" href={withBasePath('/blog/')}>Browse the archive</a>
    </div>

    <div class="post-grid">
      {latestPosts.map((post) => (
        <PostCard post={post} />
      ))}
    </div>
  </section>

  <section class="section split reveal-slower">
    <article class="glass-card quote-panel">
      <p class="label">Studio Note</p>
      <blockquote>
        Beautiful systems are often the ones that remove friction without advertising the fact.
      </blockquote>
      <p class="section-copy">
        This design leans editorial rather than product-like: warm paper tones, expressive type,
        measured animation, and enough structure to make technical writing feel ceremonial.
      </p>
    </article>

    <article class="glass-card list-card">
      <p class="label">Working Principles</p>
      <ul class="principle-list">
        {siteConfig.principles.map((principle) => (
          <li>{principle}</li>
        ))}
      </ul>

      <div class="divider"></div>

      <p class="label">Themes</p>
      <div class="pill-list">
        {distinctTags.map((tag) => (
          <span class="pill">{tag}</span>
        ))}
      </div>
    </article>
  </section>
</BaseLayout>
