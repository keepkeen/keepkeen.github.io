---
import BaseLayout from '../layouts/BaseLayout.astro';
import { siteConfig } from '../site.config';
import { publicEmail, publicSocialLinks } from '../utils/site';

const mailHref = publicEmail ? `mailto:${publicEmail}` : undefined;
const githubHref = publicSocialLinks.find((item) => item.label === 'GitHub')?.href;
---

<BaseLayout title="About" description="About Liuliming, the writing behind this publication.">
  <section class="page-intro reveal">
    <p class="eyebrow">About Me</p>
    <h1>Building from inside the work, then writing about what lasts.</h1>
    <p class="section-copy">{siteConfig.about.intro}</p>
  </section>

  <section class="about-grid reveal-delay">
    <article class="glass-card story-panel">
      <p class="label">Short Bio</p>
      {siteConfig.about.body.map((paragraph) => (
        <p>{paragraph}</p>
      ))}
    </article>

    <aside class="glass-card desk-panel">
      <p class="label">Coordinates</p>
      <div class="fact-grid">
        {siteConfig.deskFacts.map((fact) => (
          <div class="fact-item">
            <span>{fact.label}</span>
            <strong>{fact.value}</strong>
          </div>
        ))}
      </div>

      <div class="divider"></div>

      <p class="label">Right Now</p>
      <ul class="note-list">
        {siteConfig.about.now.map((item) => (
          <li>{item}</li>
        ))}
      </ul>

      {(mailHref || githubHref) && <div class="divider"></div>}

      <div class="hero-actions">
        {mailHref && (
          <a class="button button-primary" href={mailHref}>
            Start a conversation
          </a>
        )}
        {githubHref && (
          <a class="button" href={githubHref} target="_blank" rel="noreferrer">
            View GitHub
          </a>
        )}
      </div>
    </aside>
  </section>

  <section class="section reveal-slower">
    <div class="section-header editorial-header">
      <div>
        <p class="eyebrow">Trajectory</p>
        <h2 class="section-title">A few persistent directions.</h2>
      </div>
      <p class="section-copy">
        I tend to return to the same axis: systems, judgment, style, and the slower forms of
        compounding that only become visible after years.
      </p>
    </div>

    <div class="trajectory-list">
      {siteConfig.about.journey.map((item) => (
        <article class="glass-card trajectory-item">
          <span class="topic-index">{item.period}</span>
          <h3>{item.title}</h3>
          <p>{item.description}</p>
        </article>
      ))}
    </div>
  </section>

  <section class="section reveal-slower">
    <div class="tri-panel">
      <article class="glass-card note-panel">
        <p class="label">What I Value</p>
        <ul class="principle-list">
          {siteConfig.about.values.map((value) => (
            <li>{value}</li>
          ))}
        </ul>
      </article>

      <article class="glass-card quote-panel">
        <p class="label">Design Belief</p>
        <blockquote>
          The interface should carry taste quietly, so the writing arrives with more force.
        </blockquote>
      </article>

      <article class="glass-card note-panel">
        <p class="label">Colophon</p>
        <p class="colophon-text">{siteConfig.about.colophon}</p>
        {githubHref && (
          <a class="text-link" href={githubHref} target="_blank" rel="noreferrer">
            Visit my GitHub
          </a>
        )}
      </article>
    </div>
  </section>
</BaseLayout>
