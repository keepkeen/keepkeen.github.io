---
import BaseLayout from '../layouts/BaseLayout.astro';
import { siteConfig } from '../site.config';
import { publicEmail, publicSocialLinks } from '../utils/site';
import { getAboutPageJsonLd, getBreadcrumbJsonLd } from '../utils/structured-data';

const mailHref = publicEmail ? `mailto:${publicEmail}` : undefined;
const githubHref = publicSocialLinks.find((item) => item.label === 'GitHub')?.href;
const siteOrigin = Astro.site ?? new URL(siteConfig.siteUrl);
const jsonLd = [
  getAboutPageJsonLd(siteOrigin),
  getBreadcrumbJsonLd([
    { name: 'Home', url: new URL(import.meta.env.BASE_URL, siteOrigin).toString() },
    { name: 'About', url: new URL('about/', new URL(import.meta.env.BASE_URL, siteOrigin)).toString() }
  ])
];
---

<BaseLayout
  title="About"
  description="About Liuliming, the writing behind this publication."
  keywords={['about', 'author', 'engineering', 'writing']}
  jsonLd={jsonLd}
>
  <section class="editorial-hero about-hero">
    <div class="editorial-hero-main">
      <p class="eyebrow">About</p>
      <h1>Building inside the work, then writing about what lasts.</h1>
      <p class="section-copy">{siteConfig.about.intro}</p>
    </div>

    <div class="editorial-hero-side">
      <div class="fact-grid">
        {siteConfig.deskFacts.map((fact) => (
          <div class="fact-item">
            <span>{fact.label}</span>
            <strong>{fact.value}</strong>
          </div>
        ))}
      </div>

      <p class="hero-signature">{siteConfig.about.colophon}</p>

      {(mailHref || githubHref) && (
        <div class="hero-links">
          {mailHref && <a class="text-link" href={mailHref}>Start a conversation</a>}
          {githubHref && (
            <a class="text-link" href={githubHref} target="_blank" rel="noreferrer">
              Visit GitHub
            </a>
          )}
        </div>
      )}
    </div>
  </section>

  <section class="section editorial-section">
    <div class="section-rail">
      <div class="section-rail-head">
        <p class="eyebrow">Profile</p>
        <h2 class="section-title">The writing behind the publication.</h2>
      </div>
      <div class="section-rail-body section-rail-body-columns">
        <div class="body-stack">
          {siteConfig.about.body.map((paragraph) => (
            <p>{paragraph}</p>
          ))}
        </div>

        <div class="body-stack">
          <div>
            <p class="panel-label">Right now</p>
            <ul class="plain-list">
              {siteConfig.about.now.map((item) => (
                <li>{item}</li>
              ))}
            </ul>
          </div>

          <div class="divider"></div>

          <div>
            <p class="panel-label">What I value</p>
            <ul class="plain-list">
              {siteConfig.about.values.map((value) => (
                <li>{value}</li>
              ))}
            </ul>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="section editorial-section">
    <div class="section-rail">
      <div class="section-rail-head">
        <p class="eyebrow">Trajectory</p>
        <h2 class="section-title">A few persistent directions.</h2>
      </div>
      <div class="section-rail-body">
        <div class="stack-list">
          {siteConfig.about.journey.map((item) => (
            <article class="list-entry list-entry-compact">
              <div class="entry-topline">
                <span>{item.period}</span>
              </div>
              <div class="list-entry-main">
                <div>
                  <h3>{item.title}</h3>
                  <p>{item.description}</p>
                </div>
              </div>
            </article>
          ))}
        </div>
      </div>
    </div>
  </section>

  <section class="section editorial-section">
    <div class="section-rail">
      <div class="section-rail-head">
        <p class="eyebrow">Notes</p>
        <h2 class="section-title">How the work is framed right now.</h2>
      </div>
      <div class="section-rail-body section-rail-body-columns">
        <div>
          <p class="panel-label">Current questions</p>
          <ol class="number-list">
            {siteConfig.currentQuestions.map((item) => (
              <li>{item}</li>
            ))}
          </ol>
        </div>

        <div class="body-stack">
          <div>
            <p class="panel-label">Colophon</p>
            <p class="panel-copy">{siteConfig.about.colophon}</p>
          </div>

          {githubHref && (
            <div>
              <a class="text-link" href={githubHref} target="_blank" rel="noreferrer">
                Visit my GitHub
              </a>
            </div>
          )}
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
